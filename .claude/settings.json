{
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ntn_b65450758806zVyAKVBTXBNw3EuRIE9M7oW7fCcTRssazc\", \"Notion-Version\": \"2022-06-28\"}"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "handler": {
          "type": "command",
          "command": "bash .claude/hooks/chart-counter.sh"
        }
      },
      {
        "matcher": "Bash",
        "handler": {
          "type": "command",
          "command": "bash .claude/hooks/script-logger.sh"
        }
      }
    ],
    "Stop": [
      {
        "handler": {
          "type": "command",
          "command": "bash .claude/hooks/validate-phases.sh"
        }
      }
    ]
  }
}
